# --- Application ---
PYTHON_ENV=dev
HOST=0.0.0.0
PORT=8089
LOG_LEVEL=INFO

# --- Auth ---
JWT_SECRET=
USER_ID_HEADER=x-user-id

# --- DB ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aiadocuments
DB_USER=aiauser
DB_PASSWORD=
DB_SCHEMA=backend

# --- AWS (S3 + SQS via aiobotocore) ---
AWS_REGION=eu-west-2
AWS_DEFAULT_REGION=eu-west-2

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# S3 Configuration
S3_BUCKET_NAME=pocldnaia001
S3_UPLOAD_PREFIX=uploaded_docs

# Orchestrator
ORCHESTRATOR_URL=http://localhost:8001
ORCHESTRATOR_PORT=8001

# --- Upload limits ---
MAX_FILE_UPLOAD=50  # MB