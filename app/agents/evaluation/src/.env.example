# Anthropic API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# PostgreSQL — checklist questions database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD=your-database-password

# SharePoint / Office 365 integration
SHAREPOINT_SITE_URL=https://yourorg.sharepoint.com/sites/yoursite
SHAREPOINT_CLIENT_ID=your-azure-app-client-id
SHAREPOINT_CLIENT_SECRET=your-azure-app-client-secret
SHAREPOINT_LIBRARY_NAME=Documents
