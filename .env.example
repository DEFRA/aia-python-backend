# AWS Configuration
AWS_REGION=eu-west-2
AWS_DEFAULT_REGION=eu-west-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# EMF Configuration
AWS_EMF_ENVIRONMENT=local
AWS_EMF_AGENT_ENDPOINT=tcp://127.0.01:25888
AWS_EMF_LOG_GROUP_NAME=log-group-name
AWS_EMF_LOG_STREAM_NAME=log-stream-name
AWS_EMF_NAMESPACE=namespace
AWS_EMF_SERVICE_NAME=service-name
AWS_EMF_SERVICE_TYPE=python-backend-service

# Application Secrets
JWT_SECRET=your-secret-key-at-least-32-chars

# S3 Configuration
S3_BUCKET_NAME=docsupload

# Database Configuration
POSTGRES_URI=postgresql://aiauser:<Password>@localhost:5432/aia_documents

# Worker Configuration
WORKER_STUCK_TASK_TIMEOUT_MINUTES=120

# SQS Queues
TASK_QUEUE_URL=http://localhost:4566/000000000000/aia-tasks
STATUS_QUEUE_URL=http://localhost:4566/000000000000/aia-status

# Orchestrator
ORCHESTRATOR_URL=http://localhost:8001
ORCHESTRATOR_PORT=8001
ORCHESTRATOR_AGENT_TIMEOUT_SECONDS=480
ORCHESTRATOR_DEFAULT_AGENT_TYPE=general
