# AWS Configuration
AWS_REGION=eu-west-2
AWS_DEFAULT_REGION=eu-west-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=test

# Remove this — tells the SDK to use real AWS endpoints
AWS_ENDPOINT_URL=http://localhost:4566

# EMF Configuration
AWS_EMF_ENVIRONMENT=local
AWS_EMF_AGENT_ENDPOINT=tcp://127.0.01:25888
AWS_EMF_LOG_GROUP_NAME=log-group-name
AWS_EMF_LOG_STREAM_NAME=log-stream-name
AWS_EMF_NAMESPACE=namespace
AWS_EMF_SERVICE_NAME=service-name
AWS_EMF_SERVICE_TYPE=python-backend-service

# Application Secrets
JWT_SECRET=your-secret-key-at-least-32-chars

# S3 Configuration
S3_BUCKET_NAME=<DOCS_BUCKET_NAME>
S3_UPLOAD_PREFIX=<OPTIONAL_PREFIX>

# Database Configuration
POSTGRES_URI=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>

# Worker Configuration
WORKER_STUCK_TASK_TIMEOUT_MINUTES=120

# SQS Queues
TASK_QUEUE_URL=http://localhost:4566/<ACCOUNT_ID>/<TASK_QUEUE_NAME>
STATUS_QUEUE_URL=http://localhost:4566/<ACCOUNT_ID>/<STATUS_QUEUE_NAME>

# Orchestrator
ORCHESTRATOR_URL=http://localhost:8001
ORCHESTRATOR_PORT=8001
AGENT_TIMEOUT_SECONDS=480
ORCHESTRATOR_DEFAULT_AGENT_TYPE=general
MAX_PRIORITY_ACTIONS=10

# ---------------------------------------------------------------------------
# Data Pipeline (app/datapipeline)
# ---------------------------------------------------------------------------
#
# Local PostgreSQL via Podman:
#   ./scripts/start-datapipeline-dev.sh   # start (reads this .env automatically)
#   podman stop  aia-datapipeline-db      # stop
#   podman rm -f aia-datapipeline-db      # remove container
#
# The DB_* vars below are used by both the script and main.py.
# ---------------------------------------------------------------------------

# Database — separate vars from POSTGRES_URI so the Lambda can set them
# independently (Lambda env vars, not a connection string).
# These match the Podman compose defaults in app/datapipeline/docker-compose.yml.
DB_HOST=<DB_HOST>
DB_PORT=<DB_PORT>
DB_NAME=<DB_NAME>
DB_USER=<DB_USER>
DB_PASSWORD=<DB_PASSWORD>

# SharePoint / Microsoft Graph API
SHAREPOINT_TENANT_ID=<SHAREPOINT_TENANT_ID>
SHAREPOINT_CLIENT_ID=<SHAREPOINT_APP_CLIENT_ID>
SHAREPOINT_CLIENT_SECRET=<SHAREPOINT_APP_CLIENT_SECRET>

# Anthropic Bedrock
# AWS_DEFAULT_REGION and AWS_ACCESS_KEY_ID are already set above
MODEL_ID=anthropic.claude-3-7-sonnet-20250219-v1:0

# Feature flag — set to true to load policy URLs from
# app/datapipeline/data/policy_sources.json instead of the database.
# With Podman running, set to false — source_path_policydoc is seeded by init.sql.
# Set to true to skip the DB read entirely (useful when DB is not running).
USE_LOCAL_POLICY_SOURCES=false
# LOCAL_POLICY_SOURCES_PATH=/absolute/path/to/policy_sources.json  # optional override

# Debug output — write per-URL files with source URL, raw content, and questions
# Files land in app/datapipeline/debug/ (or DEBUG_OUTPUT_DIR if set)
SAVE_DEBUG_OUTPUT=false
# DEBUG_OUTPUT_DIR=/absolute/path/to/output/dir  # optional override

# --- LLM provider ---
# "anthropic" uses the direct Anthropic API (ANTHROPIC_API_KEY required).
# "bedrock"   uses AWS Bedrock (AWS credentials required; no API key needed).
LLM_PROVIDER=bedrock
# ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>